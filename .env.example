# Swiss Invoice Compliance AI - Environment Configuration
# Copy this file to .env and fill in your values

APP_NAME="Swiss Invoice Compliance AI"
APP_VERSION="1.0.0"
DEBUG=true

DATABASE_URL=sqlite:///./swiss_invoices.db
# DATABASE_URL=postgresql://user:password@localhost:5432/swiss_invoices

UPLOAD_DIR=./uploads
EXPORT_DIR=./exports
MAX_UPLOAD_SIZE_MB=20

# Options: "tesseract" | "mock" | "easyocr"
OCR_ENGINE=mock
TESSERACT_LANGUAGES=deu+fra+ita+eng
# TESSERACT_CMD=C:/Program Files/Tesseract-OCR/tesseract.exe

ACCEPTED_CURRENCIES=CHF,EUR,USD
API_KEY=changeme-in-production
